<Window x:Class="DeltaApp.Desktop.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Atualização" Height="164" Width="380"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" WindowStartupLocation="CenterOwner" FontFamily="Segoe UI">
    <Border Background="{StaticResource Surface}" CornerRadius="14" Padding="26"
            BorderBrush="{StaticResource Line}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.2" Color="#1B2430"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="Atualizando Delta Decisão" FontFamily="Segoe UI Semibold" FontSize="15"
                       Foreground="{StaticResource Ink}"/>
            <TextBlock x:Name="StatusText" Text="Baixando a nova versão…" Foreground="{StaticResource Muted}"
                       FontSize="12" Margin="0,4,0,16"/>
            <ProgressBar x:Name="Bar" Height="8" Minimum="0" Maximum="100"
                         Foreground="{StaticResource Green}" Background="{StaticResource Line}"
                         BorderThickness="0"/>
            <TextBlock x:Name="Pct" Text="0%" FontFamily="{StaticResource Mono}" FontSize="12"
                       Foreground="{StaticResource Graphite}" Margin="0,8,0,0" HorizontalAlignment="Right"/>
        </StackPanel>
    </Border>
</Window>
