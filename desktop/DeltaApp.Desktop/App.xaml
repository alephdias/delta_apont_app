<Application x:Class="DeltaApp.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DeltaApp.Desktop"
             StartupUri="LoginWindow.xaml">
    <Application.Resources>
        <!-- Paleta "Cronômetro" -->
        <SolidColorBrush x:Key="Ink" Color="#181C22"/>
        <SolidColorBrush x:Key="Graphite" Color="#414B57"/>
        <SolidColorBrush x:Key="Muted" Color="#79838F"/>
        <SolidColorBrush x:Key="Faint" Color="#A7AFB9"/>
        <SolidColorBrush x:Key="Paper" Color="#ECEEF1"/>
        <SolidColorBrush x:Key="Surface" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Surface2" Color="#F3F5F7"/>
        <SolidColorBrush x:Key="Line" Color="#DBE0E6"/>
        <SolidColorBrush x:Key="Line2" Color="#C7CFD8"/>
        <SolidColorBrush x:Key="Green" Color="#0FA671"/>
        <SolidColorBrush x:Key="GreenDeep" Color="#0B7D55"/>
        <SolidColorBrush x:Key="GreenSoft" Color="#E4F3EC"/>
        <SolidColorBrush x:Key="Danger" Color="#CE4A48"/>

        <FontFamily x:Key="Mono">Consolas</FontFamily>
        <FontFamily x:Key="Sans">Segoe UI</FontFamily>

        <!-- Botões -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Ink}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Graphite}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line2}"/>
        </Style>

        <Style x:Key="OkButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource Green}"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Danger}"/>
            <Setter Property="BorderBrush" Value="#F0C9C8"/>
        </Style>

        <!-- Card -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <!-- Eyebrow / rótulos -->
        <Style x:Key="Eyebrow" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Inputs -->
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Ink}"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{StaticResource Surface}" BorderBrush="{StaticResource Line2}"
                                BorderThickness="1" CornerRadius="7">
                            <Grid>
                                <TextBlock x:Name="ph" Text="{TemplateBinding Tag}" Foreground="{StaticResource Faint}"
                                           Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="ph" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Ink}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Ink}"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Line2}"
                                BorderThickness="1" CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid limpo -->
        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource Surface2}"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <!-- Chip SO/PA + número para as tabelas -->
        <DataTemplate x:Key="CodeChip">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border CornerRadius="3" Padding="4,1" Margin="0,0,6,0" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource Ink}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Type}" Value="PA">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource Ink}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding Type}" FontFamily="{StaticResource Mono}" FontSize="9" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="White"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Type}" Value="PA">
                                        <Setter Property="Foreground" Value="{StaticResource Ink}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
                <TextBlock Text="{Binding Number}" FontFamily="{StaticResource Mono}" FontSize="12.5"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>

        <Style x:Key="CleanGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F1F3F5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="RowBackground" Value="{StaticResource Surface}"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="RowHeight" Value="34"/>
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource GridHeader}"/>
        </Style>

        <!-- DatePicker limpo -->
        <Style TargetType="DatePickerTextBox">
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePickerTextBox">
                        <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"
                                      VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Line2}"
                                BorderThickness="1" CornerRadius="7" Padding="10,0,6,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="0" VerticalAlignment="Center"
                                                   Background="Transparent" BorderThickness="0"/>
                                <Button x:Name="PART_Button" Grid.Column="1" Width="26" Focusable="False"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Foreground="{StaticResource Muted}" Content="📅" FontSize="12"/>
                                <Popup x:Name="PART_Popup" StaysOpen="False" AllowsTransparency="True"
                                       Placement="Bottom" PlacementTarget="{Binding ElementName=PART_TextBox}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
