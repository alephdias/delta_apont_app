<Window x:Class="DeltaApp.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Delta Decisão" Height="860" Width="1080" MinHeight="640" MinWidth="900"
        WindowStartupLocation="CenterScreen" Background="{StaticResource Paper}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="DarkGhost" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E7EAEF"/>
            <Setter Property="BorderBrush" Value="#39424E"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Padding" Value="11,6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Topbar em tinta com a logo -->
        <Border Grid.Row="0" Background="{StaticResource Ink}" Padding="20,12">
            <DockPanel LastChildFill="False">
                <Image Source="/Assets/logo.png" Height="26" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                <Button Content="Sair" Style="{StaticResource DarkGhost}" DockPanel.Dock="Right" Click="Logout_Click"/>
                <Button Content="🕒 Janelinha" Style="{StaticResource DarkGhost}" DockPanel.Dock="Right"
                        Margin="0,0,8,0" Click="OpenWidget_Click"/>
                <TextBlock x:Name="EmailText" Foreground="#9AA3AF" FontSize="12" VerticalAlignment="Center"
                           DockPanel.Dock="Right" Margin="0,0,16,0"/>
            </DockPanel>
        </Border>

        <!-- Corpo -->
        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1.25*"/>
            </Grid.ColumnDefinitions>

            <!-- Esquerda -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Nova solicitação" Style="{StaticResource CardTitle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ComboBox x:Name="TypeCombo" Width="64" SelectedIndex="0" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="SO"/>
                                <ComboBoxItem Content="PA"/>
                            </ComboBox>
                            <TextBox x:Name="NumberBox" Width="120" Margin="8,0,0,0" Tag="Número"
                                     ToolTip="Número (ex.: 26061542)"/>
                            <Button Content="Colar SO/PA" Style="{StaticResource GhostButton}" Margin="8,0,0,0"
                                    Click="ColarSoPa_Click" ToolTip="Lê SO-###### ou PA-###### da área de transferência"/>
                        </StackPanel>
                        <TextBlock Text="CLIENTE (OPCIONAL)" Style="{StaticResource Eyebrow}" Margin="0,4,0,4"/>
                        <ComboBox x:Name="ClientCombo" IsEditable="True" Margin="0,0,0,8"
                                  VerticalContentAlignment="Center" ToolTip="Escolha um cliente ou digite um novo"/>
                        <TextBox x:Name="TitleBox" Margin="0,0,0,12" Tag="Título / descrição (opcional)"
                                 ToolTip="Título / descrição breve"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Criar solicitação" Style="{StaticResource PrimaryButton}" Click="Create_Click"/>
                            <Button Content="Colar e iniciar ▶" Style="{StaticResource OkButton}" Margin="8,0,0,0"
                                    Click="ColarEIniciar_Click"
                                    ToolTip="Cria a SO/PA da área de transferência e já inicia o cronômetro"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="18,16,18,8">
                            <TextBlock Text="Solicitações" Style="{StaticResource CardTitle}" Margin="0"
                                       HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <CheckBox x:Name="OnlyDayCheck" Content="Só as do dia" HorizontalAlignment="Right"
                                      VerticalAlignment="Center" Foreground="{StaticResource Graphite}" FontSize="12"
                                      Checked="OnlyDay_Changed" Unchecked="OnlyDay_Changed"
                                      ToolTip="Mostra só as solicitações que você atendeu no dia selecionado"/>
                        </Grid>
                        <DataGrid x:Name="SolGrid" Style="{StaticResource CleanGrid}"
                                  SelectionChanged="SolGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Código" Width="120" CellTemplate="{StaticResource CodeChip}"/>
                                <DataGridTextColumn Header="Cliente" Binding="{Binding ClientName}" Width="*"/>
                                <DataGridTextColumn Header="Título" Binding="{Binding Title}" Width="1.3*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusLabel}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Direita -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="240"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="CRONÔMETRO" Style="{StaticResource Eyebrow}"/>
                        <TextBlock x:Name="RunningCode" Text="Nenhum cronômetro ativo" FontSize="15"
                                   Foreground="{StaticResource Muted}" Margin="0,2,0,2"/>
                        <TextBlock x:Name="ElapsedLabel" Text="00:00:00" FontFamily="{StaticResource Mono}"
                                   FontSize="46" FontWeight="Bold" Foreground="{StaticResource Ink}" Margin="0,2,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="▶ Iniciar selecionada" Style="{StaticResource PrimaryButton}" Click="Start_Click"/>
                            <Button x:Name="PauseButton" Content="⏸ Pausar" Style="{StaticResource GhostButton}"
                                    Margin="8,0,0,0" Click="Pause_Click"/>
                            <Button x:Name="FinishButton" Content="■ Finalizar" Style="{StaticResource OkButton}"
                                    Margin="8,0,0,0" Click="Finish_Click"/>
                        </StackPanel>
                        <TextBlock Text="atalho global: Ctrl+Alt+P pausa/continua" Style="{StaticResource Eyebrow}"
                                   Margin="0,12,0,0"/>
                        <CheckBox x:Name="AutoPauseCheck" Content="Pausar quando eu ficar ausente (10 min)"
                                  Foreground="{StaticResource Graphite}" FontSize="12" Margin="0,8,0,0"
                                  Checked="AutoPause_Changed" Unchecked="AutoPause_Changed"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock x:Name="SelectedHeader" Text="Nenhuma solicitação selecionada"
                                   Style="{StaticResource CardTitle}"/>

                        <TextBlock Text="OBSERVAÇÕES · O QUE FOI FEITO" Style="{StaticResource Eyebrow}" Margin="0,0,0,4"/>
                        <TextBox x:Name="NotesBox" AcceptsReturn="True" TextWrapping="Wrap" Height="64"
                                 VerticalScrollBarVisibility="Auto" Padding="9,7"
                                 Background="{StaticResource Surface}" BorderBrush="{StaticResource Line2}"
                                 BorderThickness="1" Foreground="{StaticResource Ink}">
                            <TextBox.Template>
                                <ControlTemplate TargetType="TextBox">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1" CornerRadius="7">
                                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                    </Border>
                                </ControlTemplate>
                            </TextBox.Template>
                        </TextBox>
                        <Button Content="Salvar observações" Style="{StaticResource GhostButton}"
                                HorizontalAlignment="Left" Margin="0,8,0,16" Click="SaveNotes_Click"/>

                        <TextBlock Text="EVIDÊNCIAS" Style="{StaticResource Eyebrow}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="EvidenceBox" Width="180" Tag="Colar um link / caminho"
                                     ToolTip="Cole um link / caminho"/>
                            <Button Content="Link" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Click="AddEvidence_Click"/>
                            <Button Content="Anexar" Style="{StaticResource GhostButton}" Margin="8,0,0,0" Click="AttachFile_Click"/>
                            <Button Content="Colar print" Style="{StaticResource GhostButton}" Margin="8,0,0,0"
                                    Click="PastePrint_Click" ToolTip="Cola a imagem da área de transferência (Ctrl+V)"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="18,16,18,8">
                            <TextBlock Text="Meu dia" Style="{StaticResource CardTitle}" Margin="0"
                                       HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <DatePicker x:Name="DatePick" Width="130" SelectedDateChanged="DatePick_Changed"/>
                                <Button Content="Atualizar" Style="{StaticResource GhostButton}" Margin="8,0,0,0" Click="Refresh_Click"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="DayTotals" DockPanel.Dock="Top" Foreground="{StaticResource Muted}"
                                   FontFamily="{StaticResource Mono}" FontSize="12" Margin="18,0,18,6"/>
                        <WrapPanel x:Name="DayMeter" DockPanel.Dock="Top" Margin="18,0,18,12"/>
                        <DataGrid x:Name="DayGrid" Style="{StaticResource CleanGrid}">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Código" Width="130" CellTemplate="{StaticResource CodeChip}"/>
                                <DataGridTextColumn Header="Cliente" Binding="{Binding ClientName}" Width="*"/>
                                <DataGridTextColumn Header="Início" Binding="{Binding StartText}" Width="66"/>
                                <DataGridTextColumn Header="Fim" Binding="{Binding EndText}" Width="80"/>
                                <DataGridTextColumn Header="Real" Binding="{Binding RealText}" Width="66"/>
                                <DataGridTextColumn Header="Apontado" Binding="{Binding AdjustedText}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
