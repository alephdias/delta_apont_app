<Window x:Class="DeltaApp.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Delta Apont" Height="640" Width="1040"
        WindowStartupLocation="CenterScreen" Background="{StaticResource Bg}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="16,10">
            <DockPanel LastChildFill="False">
                <Border Background="{StaticResource Accent}" CornerRadius="7" Width="28" Height="28"
                        DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="Δ" Foreground="White" FontWeight="Bold" FontSize="15"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Delta Apont" FontWeight="SemiBold" FontSize="15" Margin="10,0,20,0"
                           VerticalAlignment="Center" Foreground="{StaticResource Text}" DockPanel.Dock="Left"/>
                <TextBlock Text="Dia:" VerticalAlignment="Center" Foreground="{StaticResource Muted}"
                           DockPanel.Dock="Left" Margin="0,0,6,0"/>
                <DatePicker x:Name="DatePick" DockPanel.Dock="Left" VerticalAlignment="Center" Width="130"
                            SelectedDateChanged="DatePick_Changed"/>
                <Button Content="Atualizar" Style="{StaticResource GhostButton}" DockPanel.Dock="Left"
                        Margin="8,0,0,0" Click="Refresh_Click"/>

                <Button Content="Sair" Style="{StaticResource GhostButton}" DockPanel.Dock="Right"
                        Click="Logout_Click"/>
                <Button Content="🕒 Janelinha" Style="{StaticResource GhostButton}" DockPanel.Dock="Right"
                        Margin="0,0,8,0" Click="OpenWidget_Click"/>
                <TextBlock x:Name="EmailText" VerticalAlignment="Center" Foreground="{StaticResource Muted}"
                           DockPanel.Dock="Right" Margin="0,0,12,0"/>
            </DockPanel>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1.25*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: nova solicitacao + lista -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Nova solicitação" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource Text}" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ComboBox x:Name="TypeCombo" Width="70" SelectedIndex="0" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="SO"/>
                                <ComboBoxItem Content="PA"/>
                            </ComboBox>
                            <TextBox x:Name="NumberBox" Width="180" Margin="8,0,0,0"
                                     ToolTip="Número (ex.: 26061542)"/>
                        </StackPanel>
                        <ComboBox x:Name="ClientCombo" IsEditable="True" Margin="0,0,0,8"
                                  VerticalContentAlignment="Center"
                                  ToolTip="Escolha um cliente ou digite um novo"/>
                        <TextBox x:Name="TitleBox" Margin="0,0,0,10" ToolTip="Título / descrição breve"/>
                        <Button Content="Criar solicitação" Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Left" Click="Create_Click"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                    <DockPanel>
                        <TextBlock Text="Solicitações" FontWeight="SemiBold" FontSize="14" DockPanel.Dock="Top"
                                   Foreground="{StaticResource Text}" Margin="16,14,16,8"/>
                        <DataGrid x:Name="SolGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  BorderThickness="0" Background="Transparent" RowBackground="White"
                                  CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Código" Binding="{Binding Code}" Width="120"/>
                                <DataGridTextColumn Header="Cliente" Binding="{Binding ClientName}" Width="*"/>
                                <DataGridTextColumn Header="Título" Binding="{Binding Title}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Right: cronometro + evidencia + dia -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Cronômetro" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource Text}"/>
                        <TextBlock x:Name="RunningCode" Text="Nenhum cronômetro ativo" FontSize="15"
                                   Foreground="{StaticResource Muted}" Margin="0,8,0,0"/>
                        <TextBlock x:Name="ElapsedLabel" Text="00:00:00" FontSize="42" FontWeight="Bold"
                                   Foreground="{StaticResource Text}" Margin="0,2,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="▶ Iniciar selecionada" Style="{StaticResource PrimaryButton}"
                                    Click="Start_Click"/>
                            <Button x:Name="PauseButton" Content="⏸ Pausar" Style="{StaticResource GhostButton}"
                                    Margin="8,0,0,0" Click="Pause_Click"/>
                            <Button x:Name="FinishButton" Content="■ Finalizar" Style="{StaticResource OkButton}"
                                    Margin="8,0,0,0" Click="Finish_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Evidência (link) na solicitação selecionada" FontWeight="SemiBold"
                                   FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="EvidenceBox" Width="360" ToolTip="Cole um link / caminho"/>
                            <Button Content="Adicionar" Style="{StaticResource PrimaryButton}"
                                    Margin="8,0,0,0" Click="AddEvidence_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="16,14,16,8">
                            <TextBlock Text="Meu dia" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource Text}" HorizontalAlignment="Left"/>
                            <TextBlock x:Name="DayTotals" Foreground="{StaticResource Muted}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                        <DataGrid x:Name="DayGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  BorderThickness="0" Background="Transparent" RowBackground="White"
                                  CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Código" Binding="{Binding Code}" Width="110"/>
                                <DataGridTextColumn Header="Cliente" Binding="{Binding ClientName}" Width="*"/>
                                <DataGridTextColumn Header="Início" Binding="{Binding StartText}" Width="70"/>
                                <DataGridTextColumn Header="Fim" Binding="{Binding EndText}" Width="80"/>
                                <DataGridTextColumn Header="Real" Binding="{Binding RealText}" Width="70"/>
                                <DataGridTextColumn Header="Apontado" Binding="{Binding AdjustedText}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
