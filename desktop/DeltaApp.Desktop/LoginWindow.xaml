<Window x:Class="DeltaApp.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Delta Decisão — Entrar" Height="520" Width="440"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource Paper}" FontFamily="Segoe UI">
    <Grid>
        <Border Style="{StaticResource Card}" Padding="0" Width="360" VerticalAlignment="Center"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.14" Color="#1B2430"/>
            </Border.Effect>
            <StackPanel>
                <Border Background="{StaticResource Ink}" CornerRadius="12,12,0,0" Padding="26,24">
                    <Image Source="/Assets/logo.png" Height="30" HorizontalAlignment="Left"/>
                </Border>
                <StackPanel Margin="26,22,26,26">
                    <TextBlock Text="CONTROLE DE APONTAMENTOS" Style="{StaticResource Eyebrow}"/>
                    <TextBlock Text="Entre com sua conta da empresa." Foreground="{StaticResource Muted}"
                               FontSize="13" Margin="0,0,0,18"/>

                    <TextBlock Text="E-MAIL" Style="{StaticResource Eyebrow}"/>
                    <TextBox x:Name="EmailBox" Margin="0,0,0,12"/>

                    <TextBlock Text="SENHA" Style="{StaticResource Eyebrow}"/>
                    <PasswordBox x:Name="PasswordBox" Margin="0,0,0,8"/>

                    <TextBlock x:Name="ErrorText" Foreground="{StaticResource Danger}" TextWrapping="Wrap"
                               Visibility="Collapsed" Margin="0,4"/>

                    <Button x:Name="LoginButton" Content="Entrar" Style="{StaticResource PrimaryButton}"
                            Margin="0,14,0,0" Click="LoginButton_Click" IsDefault="True"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
