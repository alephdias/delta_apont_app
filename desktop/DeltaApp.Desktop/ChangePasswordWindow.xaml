<Window x:Class="DeltaApp.Desktop.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Delta Decisão — Nova senha" Height="500" Width="440"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource Paper}" FontFamily="Segoe UI">
    <Grid>
        <Border Style="{StaticResource Card}" Padding="0" Width="360" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.14" Color="#1B2430"/>
            </Border.Effect>
            <StackPanel>
                <Border Background="{StaticResource Ink}" CornerRadius="12,12,0,0" Padding="26,24">
                    <Image Source="/Assets/logo.png" Height="30" HorizontalAlignment="Left"/>
                </Border>
                <StackPanel Margin="26,22,26,26">
                    <TextBlock Text="PRIMEIRO ACESSO" Style="{StaticResource Eyebrow}"/>
                    <TextBlock Text="Defina sua senha" FontFamily="Segoe UI Semibold" FontSize="18"
                               Foreground="{StaticResource Ink}" Margin="0,0,0,4"/>
                    <TextBlock Text="Escolha uma senha de sua preferência para continuar."
                               Foreground="{StaticResource Muted}" TextWrapping="Wrap" FontSize="13" Margin="0,0,0,18"/>

                    <TextBlock Text="NOVA SENHA" Style="{StaticResource Eyebrow}"/>
                    <PasswordBox x:Name="PasswordBox" Margin="0,0,0,12"/>

                    <TextBlock Text="CONFIRMAR SENHA" Style="{StaticResource Eyebrow}"/>
                    <PasswordBox x:Name="ConfirmBox" Margin="0,0,0,8"/>

                    <TextBlock x:Name="ErrorText" Foreground="{StaticResource Danger}" TextWrapping="Wrap"
                               Visibility="Collapsed" Margin="0,4"/>

                    <Button x:Name="SaveButton" Content="Salvar e continuar" Style="{StaticResource PrimaryButton}"
                            Margin="0,14,0,0" Click="SaveButton_Click" IsDefault="True"/>
                    <Button Content="Sair" Style="{StaticResource GhostButton}" Margin="0,8,0,0"
                            Click="Logout_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
