<Window x:Class="DeltaApp.Desktop.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Delta Apont — Nova senha" Height="440" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource Bg}">
    <Grid>
        <Border Style="{StaticResource Card}" Width="330" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Definir nova senha" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource Text}"/>
                <TextBlock Text="Primeiro acesso: escolha uma senha de sua preferência."
                           Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,16"/>

                <TextBlock Text="Nova senha" Style="{StaticResource Label}"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,12"/>

                <TextBlock Text="Confirmar senha" Style="{StaticResource Label}"/>
                <PasswordBox x:Name="ConfirmBox" Margin="0,0,0,8"/>

                <TextBlock x:Name="ErrorText" Foreground="#DC2626" TextWrapping="Wrap"
                           Visibility="Collapsed" Margin="0,4,0,4"/>

                <Button x:Name="SaveButton" Content="Salvar e continuar" Style="{StaticResource PrimaryButton}"
                        Margin="0,10,0,0" Click="SaveButton_Click" IsDefault="True"/>
                <Button Content="Sair" Style="{StaticResource GhostButton}" Margin="0,8,0,0"
                        Click="Logout_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
