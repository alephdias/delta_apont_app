# URL base da API (inclua o /api no final).
# Dev local (perfil http do backend):
VITE_API_URL=http://localhost:5213/api
# Producao (Vercel): a URL do backend no Render, ex.:
# VITE_API_URL=https://delta-apont-api.onrender.com/api

# Supabase (Auth). A anon/publishable key e publica por design.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
